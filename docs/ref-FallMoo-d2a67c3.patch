+      org.apache.iceberg.hadoop.HadoopTables tables =
+          new org.apache.iceberg.hadoop.HadoopTables(hadoopConf);
+      return tables.load(tablePath);
+    }
+  }
+
+  private static Schema projectColumns(Schema tableSchema, String[] columns) {
+    List<Types.NestedField> selected = new ArrayList<>();
+    for (String col : columns) {
+      Types.NestedField field = tableSchema.findField(col);
+      if (field != null) {
+        selected.add(field);
+      }
+    }
+    return selected.isEmpty() ? tableSchema : new Schema(selected);
+  }
