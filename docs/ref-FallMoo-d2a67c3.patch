-
-/**
- * C/C++ 与 Iceberg Java SDK 之间的 Arrow 数据桥接层.
- *
- * <p>核心流程:
- *
- * <ol>
- *   <li>调用 {@link #openTable} 打开 Iceberg 表, 内部使用 {@link VectorizedTableScanIterable} 进行向量化读取
- *   <li>调用 {@link #readNextBatch} 逐批读取, 内部通过 {@link Data#exportVector} 将 Java 侧的 {@link
- *       FieldVector} 导出为 C 语言结构体 {@link ArrowArray} / {@link ArrowSchema}
- *   <li>调用 {@link #getArrowArrayPointer} / {@link #getArrowSchemaPointer} 获取 C 结构体的原生内存地址
- *   <li>C/C++ 侧通过 JNI 拿到这些指针后, 用 Arrow C++ 的 {@code arrow::ImportArray} / {@code
- *       arrow::ImportType} 还原数据
- *   <li>每批处理完后调用 {@link #releaseBatch} 释放导出资源, 最后调用 {@link #close} 关闭读取器
- * </ol>
- *
- * <p>限制 (继承自向量化 Arrow 读取路径):
- *
- * <ul>
- *   <li>仅 Parquet 格式
- *   <li>不支持 delete file — 注意这是向量化路径的限制, 不是 Iceberg 的限制. Iceberg 的标准行式读取
- *       (Spark/Flink/Trino 等引擎使用) 完全支持 delete file, 会自动应用删除标记返回正确结果.
- *   <li>不支持 struct/list/map 复杂类型
- * </ul>
- *
- * <p>对存在 delete file 的表, 应回退到 Iceberg 标准行式读取, 而非使用此桥接类.
- */
-public class IcebergArrowBridge implements AutoCloseable {
-
-  // Arrow 内存分配器, 复用 Iceberg 全局单例, 避免自行创建/关闭导致内存泄漏
-  private final BufferAllocator allocator;
-  // Iceberg 向量化读取的可迭代对象, 底层使用 ArrowReader
-  private VectorizedTableScanIterable iterable;
-  // 批次迭代器, 每次 next() 返回一个 ColumnarBatch
-  private CloseableIterator<ColumnarBatch> iterator;
-  // 当前批次数据
-  private ColumnarBatch currentBatch;
-
-  // 导出到堆外内存的 C 结构体数组, 一列对应一个 ArrowArray + ArrowSchema
-  private ArrowArray[] exportedArrays;
-  private ArrowSchema[] exportedSchemas;
-
-  public IcebergArrowBridge() {
-    // 复用全局 allocator, 不要自己 new RootAllocator, 否则 close 时会报内存泄漏
-    this.allocator = ArrowAllocation.rootAllocator();
-  }
-
-  /**
-   * 打开 Iceberg 表, 准备向量化读取.
-   *
-   * @param table Iceberg 表对象 (通过 Catalog 加载)
-   * @param schema 要读取的列 (project schema), 为 null 则读取全部列
-   */
-  public void openTable(Table table, Schema schema) {
-    TableScan scan = table.newScan();
-    if (schema != null && !schema.columns().isEmpty()) {
-      scan = scan.project(schema);
-    }
-    this.iterable = new VectorizedTableScanIterable(scan);
-    this.iterator = iterable.iterator();
-    System.out.println("[IcebergArrowBridge] 表已打开: " + table.name());
-    if (schema != null) {
-      System.out.println("[IcebergArrowBridge] 读取列: " + schema.columns());
-    }
-  }
-
-  /**
-   * 读取下一批数据, 并将每列的 {@link FieldVector} 通过 Arrow C Data Interface 导出到堆外内存.
-   *
-   * <p>导出后, C/C++ 侧可以通过 {@link #getArrowArrayPointer(int)} 和 {@link
-   * #getArrowSchemaPointer(int)} 获取原生指针.
-   *
-   * @return true 表示有数据, false 表示读取完毕
-   */
-  public boolean readNextBatch() {
-    if (iterator == null || !iterator.hasNext()) {
-      System.out.println("[IcebergArrowBridge] 数据读取完毕, 没有更多批次");
-      return false;
-    }
-
-    // Step 1: 从 Iceberg 读取一批 ColumnarBatch (Arrow 列式格式)
-    currentBatch = iterator.next();
-    int numCols = currentBatch.numCols();
-    int numRows = currentBatch.numRows();
-    System.out.println(
-        "[IcebergArrowBridge] 读取一批数据: " + numRows + " 行, " + numCols + " 列");
-
-    // Step 2: 释放上一批的导出资源 (C 结构体)
-    releaseExports();
-
-    // Step 3: 为每列创建 ArrowArray / ArrowSchema, 并将 FieldVector 导出到 C 结构体
-    exportedArrays = new ArrowArray[numCols];
-    exportedSchemas = new ArrowSchema[numCols];
-
-    for (int i = 0; i < numCols; i++) {
-      ColumnVector col = currentBatch.column(i);   // Iceberg 列向量
-      FieldVector vector = col.getFieldVector();    // Arrow Java FieldVector
-
-      // 分配空的 C 结构体 (堆外内存)
-      exportedArrays[i] = ArrowArray.allocateNew(allocator);
-      exportedSchemas[i] = ArrowSchema.allocateNew(allocator);
-
-      // 核心步骤: 将 FieldVector 的数据导出到 C 结构体
-      // 之后可以通过 memoryAddress() 获取原生指针传给 C/C++
-      Data.exportVector(allocator, vector, null, exportedArrays[i], exportedSchemas[i]);
-
-      long arrayPtr = exportedArrays[i].memoryAddress();
-      long schemaPtr = exportedSchemas[i].memoryAddress();
-      System.out.printf(
-          "[IcebergArrowBridge]   列[%d] 已导出 -> ArrowArray*: 0x%016x, ArrowSchema*: 0x%016x%n",
-          i, arrayPtr, schemaPtr);
-    }
-
-    return true;
-  }
-
-  /** 当前批次列数 */
-  public int numColumns() {
-    return exportedArrays != null ? exportedArrays.length : 0;
-  }
-
-  /** 当前批次行数 */
-  public int numRows() {
-    return currentBatch != null ? currentBatch.numRows() : 0;
-  }
-
-  /**
-   * 获取第 col 列的 ArrowArray C 结构体的原生内存地址.
-   * C/C++ 侧强转为 {@code (ArrowArray*)} 后即可使用.
-   */
-  public long getArrowArrayPointer(int col) {
-    return exportedArrays[col].memoryAddress();
-  }
-
-  /**
-   * 获取第 col 列的 ArrowSchema C 结构体的原生内存地址.
-   * C/C++ 侧强转为 {@code (ArrowSchema*)} 后即可使用.
-   */
-  public long getArrowSchemaPointer(int col) {
-    return exportedSchemas[col].memoryAddress();
-  }
-
-  /** 释放当前批次的导出资源. 每批处理完后必须调用, 否则堆外内存泄漏. */
-  public void releaseBatch() {
-    releaseExports();
-    currentBatch = null;
-  }
-
-  /** 关闭所有 ArrowArray / ArrowSchema, 释放堆外内存 */
-  private void releaseExports() {
-    if (exportedArrays != null) {
-      for (ArrowArray arr : exportedArrays) {
-        if (arr != null) {
-          arr.close(); // 释放 C 结构体占用的堆外内存
-        }
-      }
-      exportedArrays = null;
-    }
-    if (exportedSchemas != null) {
-      for (ArrowSchema sch : exportedSchemas) {
-        if (sch != null) {
-          sch.close();
-        }
-      }
-      exportedSchemas = null;
-    }
-    System.out.println("[IcebergArrowBridge] 已释放当前批次的导出资源");
-  }
-
-  /** 关闭读取器. 注意: allocator 是全局单例, 不在此关闭. */
-  @Override
-  public void close() throws IOException {
-    releaseBatch();
-    if (iterator != null) {
-      iterator.close();
-    }
-    if (iterable != null) {
-      iterable.close();
-    }
-    // allocator 是 ArrowAllocation.rootAllocator() 全局单例, 不要 close
-    System.out.println("[IcebergArrowBridge] 读取器已关闭");
-  }
-}
