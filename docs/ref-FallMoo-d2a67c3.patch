+package org.apache.iceberg.arrow.bridge;
+
+import com.fasterxml.jackson.core.type.TypeReference;
+import com.fasterxml.jackson.databind.ObjectMapper;
+import com.fasterxml.jackson.databind.node.ArrayNode;
+import com.fasterxml.jackson.databind.node.ObjectNode;
+import java.util.Collections;
+import java.util.HashMap;
+import java.util.List;
+import java.util.Map;
+import org.apache.hadoop.conf.Configuration;
+import org.apache.iceberg.PartitionSpec;
+import org.apache.iceberg.Schema;
+import org.apache.iceberg.SortOrder;
+import org.apache.iceberg.Table;
+import org.apache.iceberg.exceptions.NoSuchNamespaceException;
+import org.apache.iceberg.hadoop.HadoopTables;
+
+/**
+ * JNI entry point — C/C++ calls this class to manage Iceberg tables via
+ * HadoopCatalog (file-system-based, no external REST service required).
+ */
+public class NativeIcebergCatalog {
+
+  private final Configuration conf;
+  private final String warehouse;
+  private final HadoopTables tables;
+  private final ObjectMapper mapper;
+
+  /**
+   * @param warehouse Iceberg warehouse root path
+   * @param confJson  Hadoop/FileIO configuration JSON (may be null or empty)
+   */
+  public NativeIcebergCatalog(String warehouse, String confJson) {
+    this.warehouse = warehouse;
+    this.conf = new Configuration();
+    this.mapper = new ObjectMapper();
+
+    // Apply FileIO configuration from confJson
+    if (confJson != null && !confJson.isEmpty()) {
+      try {
+        Map<String, String> props =
+            mapper.readValue(confJson, new TypeReference<Map<String, String>>() {});
+        for (Map.Entry<String, String> e : props.entrySet()) {
+          conf.set(e.getKey(), e.getValue());
+        }
+      } catch (Exception e) {
+        System.err.println(
+            "[NativeIcebergCatalog] failed to parse confJson: " + e.getMessage());
+      }
+    }
+
+    this.tables = new HadoopTables(conf);
+  }
+
+  /**
+   * Create an Iceberg table and return serialized LoadTableResult JSON.
+   *
+   * @param jsonRequest createTable request JSON:
+   *     <pre>{@code
+   * {
+   *   "namespace": "default",
+   *   "tableName": "test_tbl",
+   *   "schema": {"type": "struct", "schema-id": 0, "fields": [...]},
+   *   "location": "s3://..." or null,
+   *   "partitionSpec": {...} or null,
+   *   "writeOrder": {...} or null,
+   *   "stageCreate": false,
+   *   "properties": {"key": "value", ...} or null
+   * }
+   * }</pre>
+   * @return success: LoadTableResult JSON; failure: {"error":{"type":"...","message":"..."}}
+   */
+  public String createTable(String jsonRequest) {
+    try {
+      Map<String, Object> req =
+          mapper.readValue(jsonRequest, new TypeReference<Map<String, Object>>() {});
+
+      String ns = (String) req.get("namespace");
+      String tbl = (String) req.get("tableName");
+      String schemaStr = mapper.writeValueAsString(req.get("schema"));
+      String location = (String) req.get("location");
+      String partitionSpecStr =
+          req.get("partitionSpec") != null
+              ? mapper.writeValueAsString(req.get("partitionSpec"))
+              : null;
+      String writeOrderStr =
+          req.get("writeOrder") != null
+              ? mapper.writeValueAsString(req.get("writeOrder"))
+              : null;
+      Boolean stageCreate = (Boolean) req.getOrDefault("stageCreate", false);
+      @SuppressWarnings("unchecked")
+      Map<String, String> properties =
+          (Map<String, String>) req.getOrDefault("properties", Collections.emptyMap());
+
+      // Parse schema
+      Schema schema = org.apache.iceberg.SchemaParser.fromJson(schemaStr);
+
+      // Determine table location
+      String tableLocation;
+      if (location != null && !location.isEmpty()) {
+        tableLocation = location;
+      } else {
+        tableLocation = warehouse + "/" + ns + "/" + tbl;
+      }
+
+      Table table;
+      if (stageCreate != null && stageCreate) {
+        // Stage create: not yet implemented
+        return errorJson("UnsupportedOperationException",
+            "Stage create is not yet supported");
+      } else {
+        // Parse partition spec
+        PartitionSpec spec = PartitionSpec.unpartitioned();
+        if (partitionSpecStr != null && !partitionSpecStr.isEmpty()
+            && !"null".equals(partitionSpecStr)) {
+          spec = org.apache.iceberg.PartitionSpecParser.fromJson(schema, partitionSpecStr);
+        }
+
+        // Parse sort order
+        SortOrder sortOrder = SortOrder.unsorted();
+        if (writeOrderStr != null && !writeOrderStr.isEmpty()
+            && !"null".equals(writeOrderStr)) {
+          sortOrder = org.apache.iceberg.SortOrderParser.fromJson(schema, writeOrderStr);
+        }
+
+        // Create the table
+        table = tables.create(schema, spec, sortOrder, properties, tableLocation);
+      }
+
+      // Build LoadTableResult JSON
+      return buildLoadTableResult(table, tableLocation);
+
+    } catch (NoSuchNamespaceException e) {
+      return errorJson("NoSuchNamespaceException", e.getMessage());
+    } catch (org.apache.iceberg.exceptions.AlreadyExistsException e) {
+      return errorJson("AlreadyExistsException", e.getMessage());
+    } catch (Exception e) {
+      System.err.println("[NativeIcebergCatalog] createTable failed: " + e.getMessage());
+      e.printStackTrace();
+      return errorJson("RuntimeException", e.getMessage());
+    }
+  }
+
+  // ---- helpers ------------------------------------------------------------
+
+  private String buildLoadTableResult(Table table, String tableLocation) {
+    try {
+      ObjectNode result = mapper.createObjectNode();
+
+      // New table always uses v1 metadata
+      String metadataLocation = tableLocation + "/metadata/v1.metadata.json";
+      result.put("metadata-location", metadataLocation);
+
+      ObjectNode metadata = mapper.createObjectNode();
+      metadata.put("format-version", 2);
+      metadata.put("location", table.location());
+
+      // Current schema
+      Schema currentSchema = table.schema();
+      int schemaId = currentSchema.schemaId();
+      metadata.put("current-schema-id", schemaId);
+
+      // Schemas array
+      ArrayNode schemas = mapper.createArrayNode();
+      schemas.add(mapper.readTree(org.apache.iceberg.SchemaParser.toJson(currentSchema)));
+      metadata.set("schemas", schemas);
+
+      // Partition specs
+      ArrayNode partitionSpecs = mapper.createArrayNode();
+      partitionSpecs.add(mapper.readTree(
+          org.apache.iceberg.PartitionSpecParser.toJson(table.spec())));
+      metadata.set("partition-specs", partitionSpecs);
+      metadata.put("default-spec-id", table.spec().specId());
+
+      // Sort orders
+      ArrayNode sortOrders = mapper.createArrayNode();
+      sortOrders.add(mapper.readTree(
+          org.apache.iceberg.SortOrderParser.toJson(table.sortOrder())));
+      metadata.set("sort-orders", sortOrders);
+      metadata.put("default-sort-order-id", table.sortOrder().orderId());
+
+      // Empty snapshots / refs / logs for new table
+      metadata.set("snapshots", mapper.createArrayNode());
+      metadata.set("refs", mapper.createObjectNode());
+      metadata.put("current-snapshot-id", -1);
+      metadata.put("last-sequence-number", 0);
+      metadata.set("snapshot-log", mapper.createArrayNode());
+      metadata.set("metadata-log", mapper.createArrayNode());
+
+      result.set("metadata", metadata);
+      result.set("config", mapper.createObjectNode());
+
+      return mapper.writeValueAsString(result);
+    } catch (Exception e) {
+      System.err.println(
+          "[NativeIcebergCatalog] buildLoadTableResult failed: " + e.getMessage());
+      e.printStackTrace();
+      return errorJson("RuntimeException", e.getMessage());
+    }
+  }
+
+  private String errorJson(String type, String message) {
+    try {
+      ObjectNode error = mapper.createObjectNode();
+      ObjectNode errorBody = mapper.createObjectNode();
+      errorBody.put("type", type);
+      errorBody.put("message", message);
+      errorBody.set("stack", mapper.createArrayNode());
+      error.set("error", errorBody);
+      return mapper.writeValueAsString(error);
+    } catch (Exception e) {
+      return "{\"error\":{\"type\":\"RuntimeException\",\"message\":\"" + e.getMessage()
+          + "\",\"stack\":[]}}";
+    }
+  }
+}
