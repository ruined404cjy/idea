+import org.apache.iceberg.data.GenericRecord;
+import org.apache.iceberg.data.IcebergGenerics;
+import org.apache.iceberg.data.Record;
+import org.apache.iceberg.data.parquet.GenericParquetWriter;
+import org.apache.iceberg.hadoop.HadoopTables;
+import org.apache.iceberg.io.CloseableIterable;
+import org.apache.iceberg.io.FileAppender;
+import org.apache.iceberg.parquet.Parquet;
+import org.apache.iceberg.relocated.com.google.common.collect.ImmutableMap;
+import org.apache.iceberg.relocated.com.google.common.collect.Lists;
+import org.apache.iceberg.types.Types;
+import org.junit.jupiter.api.Test;
+import org.junit.jupiter.api.io.TempDir;
+
+/**
+ * GenericReader 基础验证测试 (Iceberg 标准行式读取).
+ *
+ * <p>对比向量化 Arrow 路径 (不支持 delete file):
+ *
+ * <ul>
+ *   <li>本测试验证 Iceberg 标准行式读取 ({@code IcebergGenerics.read()}) 的两种行为:
+ *       <ol>
+ *         <li>正常读取 — 读取表返回完整 {@link Record} 数据
+ *         <li>MOR (Merge-on-Read) — 添加 delete file 后, SDK 自动过滤已删除的行
+ *       </ol>
+ *   <li>核心结论: 行式读取路径原生支持 MOR, 无需调用方做任何额外工作.
+ *       而向量化 Arrow 路径 ({@link org.apache.iceberg.arrow.vectorized.VectorizedTableScanIterable})
+ *       不支持 delete file, 遇到 MOR 表直接抛出 {@link UnsupportedOperationException}.
+ * </ul>
+ */
+public class GenericReaderTest {
+
+  private static final Schema TEST_SCHEMA =
+      new Schema(
+          Types.NestedField.required(1, "id", Types.IntegerType.get()),
+          Types.NestedField.optional(2, "name", Types.StringType.get()));
+
+  @TempDir private File tempDir;
+
+  /**
+   * 测试 1 — 正常读取: 写 3 行数据, 通过 GenericReader (行式) 读回, 验证数据完整.
+   *
+   * <p>与向量化 Arrow 路径对比:
+   * 向量化路径读回的是 ColumnarBatch → Arrow C 结构体;
+   * 行式路径读回的是 GenericRecord → 直接访问字段值.
+   */
+  @Test
+  public void testGenericRead() throws Exception {
+    System.out.println("========== 测试 1: GenericReader 正常读取 ==========");
+
+    // Step 1: 创建表并写入数据
+    Table table = createTestTable();
+    writeTestData(table);
+    System.out.println("[测试] 输入数据: 3 行 -> (1, alice), (2, bob), (3, carol)");
+
+    // Step 2: 通过 IcebergGenerics (底层使用 GenericReader) 读取
+    List<Record> records = new ArrayList<>();
+    try (CloseableIterable<Record> reader = IcebergGenerics.read(table).build()) {
+      for (Record record : reader) {
+        records.add(record.copy());
+      }
+    }
+
+    // Step 3: 验证
+    System.out.println("[测试] 读取到 " + records.size() + " 行");
+    for (Record rec : records) {
+      System.out.println(
+          "[测试]   (" + rec.getField("id") + ", " + rec.getField("name") + ")");
+    }
+
+    assertThat(records).hasSize(3);
+    assertThat(records.get(0).getField("id")).isEqualTo(1);
+    assertThat(records.get(0).getField("name")).isEqualTo("alice");
+    assertThat(records.get(1).getField("id")).isEqualTo(2);
+    assertThat(records.get(1).getField("name")).isEqualTo("bob");
+    assertThat(records.get(2).getField("id")).isEqualTo(3);
+    assertThat(records.get(2).getField("name")).isEqualTo("carol");
+
+    System.out.println("[测试] testGenericRead 通过 ✓");
+  }
+
+  /**
+   * 测试 2 — MOR (Merge-on-Read): 添加 position delete file 后, GenericReader 自动过滤已删除的行.
+   *
+   * <p>流程:
+   *
+   * <ol>
+   *   <li>写 3 行数据: (1, alice), (2, bob), (3, carol)
+   *   <li>写一个 position delete file, 标记删除第 1 行 (bob, pos=1)
+   *   <li>通过 {@code newRowDelta().addDeletes()} 提交 delete file
+   *   <li>用 GenericReader 读取 → SDK 自动 apply delete file, bob 不出现
+   * </ol>
+   *
+   * <p>这与删除数据后的向量化路径行为形成鲜明对比:
+   * 同一个场景, 向量化路径直接抛异常, 而行式路径自动处理 MOR.
+   */
+  @Test
+  public void testGenericReadWithPositionDeletes() throws Exception {
+    System.out.println("========== 测试 2: GenericReader MOR 模式 ==========");
+
+    // Step 1: 创建 v2 表并写入数据
+    Table table = createTestTableWithV2Format();
+    DataFile dataFile = writeTestData(table);
+    System.out.println("[测试] 输入数据: 3 行 -> (1, alice), (2, bob), (3, carol)");
+    System.out.println("[测试] 数据文件路径: " + dataFile.location());
+
+    // Step 2: 在删除前先读取, 确认有 3 行
+    List<Record> beforeRecords = new ArrayList<>();
+    try (CloseableIterable<Record> reader = IcebergGenerics.read(table).build()) {
+      for (Record record : reader) {
+        beforeRecords.add(record.copy());
+      }
+    }
+    assertThat(beforeRecords).hasSize(3);
+    System.out.println("[测试] 删除前读取: " + beforeRecords.size() + " 行 ✓");
+
+    // Step 3: 写一个 position delete file, 删除第 1 行 (pos=1, bob)
+    // position delete file 的 schema: file_path (string), pos (long)
+    Schema posDeleteSchema =
+        new Schema(MetadataColumns.DELETE_FILE_PATH, MetadataColumns.DELETE_FILE_POS);
+
+    // 创建 position delete 记录: 指定要删除的数据文件路径和行号
+    GenericRecord posDeleteRecord = GenericRecord.create(posDeleteSchema);
+    posDeleteRecord.setField("file_path", dataFile.location());
+    posDeleteRecord.setField("pos", 1L); // 删除第 2 行 (0-based index)
+
+    // 写 position delete Parquet 文件
+    File deleteParquetFile = File.createTempFile("pos-delete", ".parquet", tempDir);
+    assertThat(deleteParquetFile.delete()).isTrue();
+
+    FileAppender<Record> appender =
+        Parquet.write(Files.localOutput(deleteParquetFile))
+            .schema(posDeleteSchema)
+            .createWriterFunc(GenericParquetWriter::create)
+            .build();
+    try {
+      appender.add(posDeleteRecord);
+    } finally {
+      appender.close();
+    }
+    System.out.println("[测试] 写 position delete 文件: " + deleteParquetFile.getAbsolutePath());
+    System.out.println("[测试]   删除目标: file_path=" + dataFile.location() + ", pos=1 (bob)");
+
+    // Step 4: 创建 DeleteFile 元数据并提交
+    DeleteFile deleteFile =
+        FileMetadata.deleteFileBuilder(PartitionSpec.unpartitioned())
+            .ofPositionDeletes()
+            .withPath(deleteParquetFile.getAbsolutePath())
+            .withFileSizeInBytes(deleteParquetFile.length())
+            .withRecordCount(1)
+            .build();
+    table.newRowDelta().addDeletes(deleteFile).commit();
+    System.out.println("[测试] 通过 RowDelta 提交 position delete file");
+
+    // Step 5: 用 GenericReader 读取 — SDK 自动 apply delete file
+    List<Record> afterRecords = new ArrayList<>();
+    try (CloseableIterable<Record> reader = IcebergGenerics.read(table).build()) {
+      for (Record record : reader) {
+        afterRecords.add(record.copy());
+      }
+    }
+
+    // Step 6: 验证 — bob (id=2) 被自动过滤, 只剩 alice 和 carol
+    System.out.println("[测试] 删除后读取: " + afterRecords.size() + " 行");
+    for (Record rec : afterRecords) {
+      System.out.println(
+          "[测试]   (" + rec.getField("id") + ", " + rec.getField("name") + ")");
+    }
+
+    assertThat(afterRecords).hasSize(2);
+    assertThat(afterRecords.get(0).getField("id")).isEqualTo(1);
+    assertThat(afterRecords.get(0).getField("name")).isEqualTo("alice");
+    assertThat(afterRecords.get(1).getField("id")).isEqualTo(3);
+    assertThat(afterRecords.get(1).getField("name")).isEqualTo("carol");
+
+    System.out.println("[测试] testGenericReadWithPositionDeletes 通过 ✓");
+    System.out.println();
+    System.out.println("[测试] ====== 结论 ======");
+    System.out.println("[测试] Iceberg 标准行式读取 (GenericReader) 原生支持 MOR:");
+    System.out.println("[测试]   - 添加 delete file 后, SDK 自动过滤已删除的行");
+    System.out.println("[测试]   - 调用方无需手动 apply delete file");
+    System.out.println("[测试]   - 对比: 向量化 Arrow 路径遇到 MOR 表直接报错");
+    System.out.println("[测试]   - 对于 C/C++ JNI 场景, 如需读 MOR 表, 应使用行式读取或先 Compaction");
+  }
+
+  /** 用 HadoopTables 创建临时 Iceberg 表 (Parquet, v1, 无分区) */
+  private Table createTestTable() {
+    HadoopTables tables = new HadoopTables();
+    return tables.create(
+        TEST_SCHEMA,
+        PartitionSpec.unpartitioned(),
+        SortOrder.unsorted(),
+        ImmutableMap.of("write.format.default", FileFormat.PARQUET.name()),
+        tempDir.toURI().toString());
+  }
+
+  /** 用 HadoopTables 创建临时 Iceberg 表 (Parquet, v2, 无分区) */
+  private Table createTestTableWithV2Format() {
+    HadoopTables tables = new HadoopTables();
+    return tables.create(
+        TEST_SCHEMA,
+        PartitionSpec.unpartitioned(),
+        SortOrder.unsorted(),
+        ImmutableMap.of(
+            "write.format.default",
+            FileFormat.PARQUET.name(),
+            TableProperties.FORMAT_VERSION,
+            "2"),
+        tempDir.toURI().toString());
+  }
+
+  /**
+   * 向表中写入测试数据 (3 行), 返回写入的 DataFile.
+   *
+   * @return 写入的 DataFile 元数据, 包含文件路径
+   */
+  private DataFile writeTestData(Table table) throws IOException {
+    List<Record> records =
+        Lists.newArrayList(
+            createRecord(1, "alice"),
+            createRecord(2, "bob"),
+            createRecord(3, "carol"));
+
+    File parquetFile = File.createTempFile("junit", ".parquet", tempDir);
+    assertThat(parquetFile.delete()).isTrue();
+
+    FileAppender<Record> appender =
+        Parquet.write(Files.localOutput(parquetFile))
+            .schema(TEST_SCHEMA)
+            .createWriterFunc(GenericParquetWriter::create)
+            .build();
+    try {
+      appender.addAll(records);
+    } finally {
+      appender.close();
+    }
+    System.out.println("[测试] 写入 Parquet 文件: " + parquetFile.getAbsolutePath());
+
+    DataFile dataFile =
+        DataFiles.builder(table.spec())
+            .withInputFile(Files.localInput(parquetFile))
+            .withRecordCount(records.size())
+            .withFormat(FileFormat.PARQUET)
+            .build();
+    table.newAppend().appendFile(dataFile).commit();
+    System.out.println("[测试] 数据已提交, 共 " + records.size() + " 行");
+
+    return dataFile;
+  }
+
+  private static Record createRecord(int id, String name) {
+    Record rec = GenericRecord.create(TEST_SCHEMA);
+    rec.setField("id", id);
+    rec.setField("name", name);
+    return rec;
+  }
+}
